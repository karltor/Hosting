rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Hosted mini-sites. Anyone can read (public sharing).
    // Only the authenticated owner can create/update/delete their own.
    match /sites/{siteId} {
      allow read: if true;

      function validSite(data) {
        return data.keys().hasAll(['ownerUid', 'name', 'files', 'sizeBytes'])
          && data.ownerUid is string
          && data.name is string && data.name.size() <= 80
          && data.files is map
          && data.files.size() <= 10
          && data.sizeBytes is int
          && data.sizeBytes <= 512000;
      }

      allow create: if request.auth != null
        && request.resource.data.ownerUid == request.auth.uid
        && validSite(request.resource.data);

      allow update: if request.auth != null
        && resource.data.ownerUid == request.auth.uid
        && request.resource.data.ownerUid == request.auth.uid
        && validSite(request.resource.data);

      allow delete: if request.auth != null
        && resource.data.ownerUid == request.auth.uid;
    }
  }
}
